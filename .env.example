# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- Stripe ---
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# --- Cloudflare R2 (image storage, zero egress) ---
# From: Cloudflare dashboard > R2 > Manage R2 API Tokens (create an "Object Read & Write" token)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=jemberry
# Public base URL the browser loads images from. Either the bucket's free
# r2.dev URL (e.g. https://pub-xxxx.r2.dev) or a custom domain
# (e.g. https://cdn.jemberry.studio). No trailing slash.
NEXT_PUBLIC_R2_PUBLIC_URL=
